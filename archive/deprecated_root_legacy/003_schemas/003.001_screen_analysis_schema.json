{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScreenAnalysis",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "screen_content": {
      "type": "string",
      "minLength": 1
    },
    "question_present": {
      "type": "boolean"
    },
    "main_answer": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "readability": {
      "type": "string",
      "enum": [
        "clear",
        "partial",
        "unreadable"
      ]
    },
    "needs_web_search": {
      "type": "boolean"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "screen_content",
    "question_present",
    "main_answer",
    "summary",
    "readability",
    "needs_web_search",
    "notes",
    "citations"
  ]
}